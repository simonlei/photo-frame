.loading-wrap,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.frame-list {
  margin-bottom: 32rpx;
}

.frame-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.frame-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.frame-info {
  flex: 1;
}

.frame-name {
  display: block;
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
}

.frame-id {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 6rpx;
}

.frame-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.bind-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1976D2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}
