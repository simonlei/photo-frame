.choose-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 12rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed #ddd;
}

.choose-icon {
  font-size: 64rpx;
  color: #1976D2;
  line-height: 1;
  margin-bottom: 8rpx;
}

.choose-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.choose-sub {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.photo-item {
  position: relative;
  width: calc((100% - 24rpx) / 3);
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  text-align: center;
  line-height: 40rpx;
  font-size: 32rpx;
  border-bottom-left-radius: 8rpx;
}

.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.overlay-done {
  background: rgba(46, 125, 50, 0.55);
}

.overlay-fail {
  background: rgba(183, 28, 28, 0.55);
}

.progress-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.status-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
}

.retry-text {
  color: #fff;
  font-size: 22rpx;
  margin-top: 6rpx;
  text-decoration: underline;
}

.upload-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1976D2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.upload-btn[disabled] {
  background-color: #90caf9;
}
